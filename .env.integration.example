# For local fake smoke mode use .env.smoke.example.
# For checking against an existing old OCR DB use .env.integration.
# Do not commit real credentials.

DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DB
RUNTIME_DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DB

EVIDENCE_SOURCE_MODE=ocr_only
SUMMARY_VERDICT_ENABLED=false
DATE_CHECK_ENABLED=false
AUDIT_ENABLED=false
RANKING_ENABLED=false

LLM_BACKEND=openrouter
LLM_API_BASE=https://openrouter.ai/api/v1
LLM_API_KEY=put_key_here
PRIMARY_MODEL=qwen/qwen3-32b
RANKING_MODEL=disabled
AUDIT_MODEL=disabled
LLM_TEMPERATURE=0
LLM_MAX_TOKENS=4096

BURATINO_WORKER_ID=buratino-real-ocr-test-1
BURATINO_WORKER_POLL_INTERVAL_SECONDS=3
BURATINO_JOB_LEASE_SECONDS=600
BURATINO_JOB_HEARTBEAT_SECONDS=60
BURATINO_MAX_CONCURRENCY=1

ALLOW_INTEGRATION_DEBUG_COMMANDS=false

LOG_LEVEL=DEBUG
OUTPUT_DIR=./output/integration
